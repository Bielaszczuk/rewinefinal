# =============================================================================
# Rewine Project - Git Ignore
# =============================================================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.project
.settings/
.classpath
*.iml

# Environment files (contain secrets)
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
logs/

# =============================================================================
# Backend (Laravel)
# =============================================================================
backend/vendor/
backend/node_modules/
backend/.env
backend/.env.backup
backend/.env.production
backend/storage/*.key
backend/storage/pail/
backend/storage/logs/*
!backend/storage/logs/.gitkeep
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/bootstrap/cache/*
backend/public/build/
backend/public/hot
backend/public/storage
backend/.phpunit.result.cache
backend/.phpunit.cache/
backend/auth.json
backend/database/*.sqlite

# Backend development/test files
backend/test_*.php
backend/create_missing_files.sh

# =============================================================================
# Frontend (Vue/Vite)
# =============================================================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/coverage/
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/

# =============================================================================
# Infrastructure
# =============================================================================
infra/*.log
infra/data/

# =============================================================================
# Misc
# =============================================================================
*.bak
*.tmp
*.temp
.cache/

